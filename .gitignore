# Claude Code CLI: .claudesignore is intentionally tracked (repo guardrails)
node_modules/
dist/*
!dist/campaigns/
!dist/campaigns/**
# Package build output (commit source only; CI builds dist)
packages/importer/dist/
.vite/
.vercel/
.next/

.env
.env.*
!.env.example

# Generated at build-time (do not commit)
public/sitemap*.xml
public/sitemap.xml
public/sw.js

# Test / tooling output
coverage/
*.tsbuildinfo
test-results/
ui-audit/

# Local npm auth at repo root (use NPM_TOKEN in env; packages/*/ may ship a tokenless stub)
/.npmrc

# OS / editor
.DS_Store
Thumbs.db
*.log

# stray files from earlier SSH tests
1234567890*

# Avoid committing secrets (use env vars / Vercel)
temp_api_key.txt
*.key
.vercel
.env*.local

# Seed decks / binaries (keep repo text-first)
docs/seed/*.pptx
